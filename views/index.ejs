<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= titulo %></title>
    <!-- Icono y Bootstrap -->
    <link rel="icon" href="/img/fc_barcelona_footballteam_18015.ico" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Tu CSS personalizado -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- Menú de Navegación -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-barca sticky-top">
      <div class="container">
        <a class="navbar-brand d-flex align-items-center" href="#">
          <span class="fw-bold">Barça Fan Page</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item"><a class="nav-link" href="#">Inicio</a></li>
            <li class="nav-item"><a class="nav-link" href="#casa">Nuestra Casa</a></li>
            <li class="nav-item"><a class="nav-link" href="#staff">Cuerpo Técnico</a></li>
            <li class="nav-item"><a class="nav-link" href="#plantilla">Plantilla</a></li>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Carrusel -->
   <div id="carouselBarca" class="carousel slide" data-bs-ride="carousel">
  <div class="carousel-inner">

    <div class="carousel-item active">
      <img src="/img/_GP10508.jpg" class="d-block w-100" alt="Camp Nou">
      <div class="carousel-caption d-none d-md-block">
      </div>
    </div>

    <div class="carousel-item">
      <img src="/img/fcb-navy-blue-3840x2160-19392.jpg" class="d-block w-100" alt="Equipo">
      <div class="carousel-caption d-none d-md-block">
      </div>
    </div>

    <div class="carousel-item">
      <img src="/img/G_x_HrhW0AAKQyi.jpg" class="d-block w-100" alt="Celebración">
    </div>

  </div>

  <!-- Controles -->
  <button class="carousel-control-prev" type="button" data-bs-target="#carouselBarca" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#carouselBarca" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>
</div>

    <!-- Header / Hero Section -->
    <header class="main-hero py-5 text-center text-white">
        <div class="container">
            <h1><%= titulo %></h1>
            <h2 class="lema fw-bold mb-4"><%= lema %></h2>
            <p class="lead mb-4"><%= subtitulo %></p>
            <button class="btn-barca"><%= mensaje %></button>
        </div>
    </header>

    <!-- Nuestra Casa -->
    <section id="casa" class="content py-5">
        <div class="container text-center">
            <h2 class="titulo-seccion">Nuestra Casa</h2>
            <h3>El mejor estadio del mundo: <strong><%= estadio %></strong></h3>
            <div class="mt-4">
                <img src="/img/_GP10508.jpg" class="img-fluid rounded shadow-lg" alt="Camp Nou">
            </div>
        </div>
    </section>

    <!-- Staff -->
    <section id="staff" class="staff py-5 bg-light">
        <div class="container">
            <h2 class="titulo-seccion">Cuerpo Técnico</h2>
            <div class="tarjeta-entrenador mx-auto">
                <img src="<%= entrenador.foto %>" alt="<%= entrenador.nombre %>" class="foto-entrenador">
                <div class="info-entrenador">
                    <h3 class="fw-bold"><%= entrenador.nombre %></h3>
                    <p class="puesto"><%= entrenador.puesto %></p>
                </div>
            </div>
        </div>
    </section>

    <!-- Plantilla -->
    <section id="plantilla" class="plantilla py-5">
        <div class="container">
            <h2 class="titulo-seccion">Conoce a nuestra Plantilla</h2>
            <div class="contenedor-jugadores">
                <% jugadores.forEach(jugador => { %>
                    <div class="tarjeta-jugador shadow-sm">
                        <img src="<%= jugador.foto %>" alt="<%= jugador.nombre %>" class="foto-perfil">
                        <span class="dorsal">#<%= jugador.dorsal %></span>
                        <h3 class="fw-bold"><%= jugador.nombre %></h3>
                        <p class="posicion"><%= jugador.posicion %></p>
                    </div>
                <% }); %>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-dark text-white pt-5 pb-4 mt-5">
        <div class="container text-center text-md-start">
            <div class="row">
                <div class="col-md-6 col-lg-6 mx-auto mt-3">
                    <h5 class="text-uppercase mb-4 font-weight-bold text-warning">FC Barcelona</h5>
                    <p>Més que un club. Landing page creada para el proyecto de pasantía.</p>
                </div>
                <div class="col-md-6 col-lg-6 mx-auto mt-3">
                    <h5 class="text-uppercase mb-4 font-weight-bold text-warning">Contacto</h5>
                    <p>Santiago, República Dominicana</p>
                    <p>info@barcafanpage.com</p>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts de Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>